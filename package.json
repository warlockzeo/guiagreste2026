{
    "name": "guiagreste",
    "version": "1.0.0",
    "description": "Catálogo de marcas de roupas - GUIAGRESTE",
    "private": true,
    "workspaces": [
        "shell",
        "server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:shell\"",
        "dev:shell": "npm run dev --workspace=shell",
        "dev:server": "npm run dev --workspace=server",
        "build": "npm run build --workspace=shell && npm run build --workspace=server",
        "start": "npm run start --workspace=server",
        "lint": "npm run lint --workspace=shell",
        "test": "npm run test --workspace=shell"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}